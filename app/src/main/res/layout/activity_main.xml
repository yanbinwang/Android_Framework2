<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="MissingConstraints">

    <data>

        <import type="com.example.common.utils.helper.ConfigHelper" />

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bgWhite"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_version_info"
            statusBar_margin="@{true}"
            android:layout_width="match_parent"
            android:layout_height="44pt"
            android:gravity="center"
            android:text="@{`VersionName: `+ConfigHelper.INSTANCE.appVersionName + ` VersionCode: ` + ConfigHelper.INSTANCE.appVersionCode}"
            android:textColor="@color/textPrimary"
            android:textSize="@dimen/textSize18"
            android:textStyle="bold"
            tools:text="VersionName: 1.0.0 VersionCode: 1" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0pt"
            android:layout_weight="1"
            android:overScrollMode="never"
            android:scrollbars="none">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10pt">

                <EditText
                    android:id="@+id/et_input_url"
                    android:layout_width="0dp"
                    android:layout_height="48pt"
                    android:layout_marginEnd="5pt"
                    android:hint="您可以在此处粘贴推流地址 :)"
                    android:singleLine="true"
                    android:textColor="@color/textPrimary"
                    android:textColorHint="@color/textHint"
                    android:textSize="@dimen/textSize12"
                    app:layout_constraintEnd_toStartOf="@id/tv_publish"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/tv_publish"
                    android:layout_width="120pt"
                    android:layout_height="48pt"
                    android:background="@drawable/selector_r5_blue"
                    android:gravity="center"
                    android:text="New"
                    android:textColor="@color/textWhite"
                    android:textSize="@dimen/textSize14"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/tv_label"
                    android:layout_width="140pt"
                    android:layout_height="48pt"
                    android:layout_marginTop="5pt"
                    android:gravity="center_vertical"
                    android:text="传输类型:"
                    android:textColor="@color/textPrimary"
                    android:textSize="@dimen/textSize14"
                    app:layout_constraintTop_toBottomOf="@id/et_input_url" />

                <Spinner
                    android:id="@+id/sp_stream_types"
                    android:layout_width="0pt"
                    android:layout_height="48pt"
                    android:layout_marginStart="5pt"
                    android:background="@drawable/shape_r5_grey"
                    android:spinnerMode="dropdown"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/tv_label"
                    app:layout_constraintTop_toTopOf="@id/tv_label" />

                <RadioGroup
                    android:id="@+id/rg_transfer"
                    android:layout_width="match_parent"
                    android:layout_height="48pt"
                    android:layout_marginTop="5pt"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toBottomOf="@id/tv_label">

                    <TextView
                        android:layout_width="140pt"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:text="传输协议:"
                        android:textColor="@color/textPrimary"
                        android:textSize="@dimen/textSize14" />

                    <RadioButton
                        android:id="@+id/rb_transfer_rtmp"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_marginStart="5pt"
                        android:checked="true"
                        android:gravity="center_vertical"
                        android:text="RTMP"
                        android:textColor="@color/textPrimary"
                        android:textSize="@dimen/textSize12" />

                    <RadioButton
                        android:id="@+id/rb_transfer_quic"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_marginStart="10pt"
                        android:gravity="center_vertical"
                        android:text="QUIC"
                        android:textColor="@color/textPrimary"
                        android:textSize="@dimen/textSize12" />

                    <RadioButton
                        android:id="@+id/rb_transfer_srt"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_marginStart="10pt"
                        android:gravity="center_vertical"
                        android:text="SRT"
                        android:textColor="@color/textPrimary"
                        android:textSize="@dimen/textSize12" />

                </RadioGroup>

                <CheckBox
                    android:id="@+id/ck_debug_mode"
                    android:layout_width="0dp"
                    android:layout_height="48pt"
                    android:layout_marginTop="5pt"
                    android:gravity="center_vertical"
                    android:text="调试模式"
                    android:textColor="@color/textPrimary"
                    android:textSize="@dimen/textSize14"
                    app:layout_constraintEnd_toStartOf="@+id/ck_audio_channel_stereo"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/rg_transfer" />

                <CheckBox
                    android:id="@+id/ck_audio_channel_stereo"
                    android:layout_width="0dp"
                    android:layout_height="48pt"
                    android:layout_marginStart="5pt"
                    android:checked="false"
                    android:gravity="center_vertical"
                    android:text="双声道"
                    android:textColor="@color/textPrimary"
                    android:textSize="@dimen/textSize14"
                    app:layout_constraintEnd_toStartOf="@id/ck_voip_record"
                    app:layout_constraintStart_toEndOf="@id/ck_debug_mode"
                    app:layout_constraintTop_toTopOf="@id/ck_debug_mode" />

                <CheckBox
                    android:id="@+id/ck_voip_record"
                    android:layout_width="0dp"
                    android:layout_height="48pt"
                    android:layout_marginStart="5pt"
                    android:checked="false"
                    android:gravity="center_vertical"
                    android:text="通话模式"
                    android:textColor="@color/textPrimary"
                    android:textSize="@dimen/textSize14"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/ck_audio_channel_stereo"
                    app:layout_constraintTop_toTopOf="@id/ck_debug_mode" />

                <CheckBox
                    android:id="@+id/ck_bluetooth_sco_on"
                    android:layout_width="wrap_content"
                    android:layout_height="48pt"
                    android:layout_marginTop="5pt"
                    android:checked="false"
                    android:text="蓝牙耳机支持"
                    android:textColor="@color/textPrimary"
                    android:textSize="@dimen/textSize14"
                    app:layout_constraintTop_toBottomOf="@id/ck_debug_mode" />

                <!-- Encoding config panel -->
                <TextView
                    android:id="@+id/tv_encoding"
                    android:layout_width="220pt"
                    android:layout_height="48pt"
                    android:layout_marginTop="5pt"
                    android:background="@drawable/selector_r5_blue"
                    android:gravity="center"
                    android:text="Toggle encoding config panel"
                    android:textColor="@color/textWhite"
                    android:textSize="@dimen/textSize14"
                    app:layout_constraintTop_toBottomOf="@+id/ck_bluetooth_sco_on" />

                <fragment
                    android:id="@+id/fragment_encoding_config"
                    android:name="com.example.live.fragment.EncodingConfigFragment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toBottomOf="@+id/tv_encoding"
                    tools:layout="@layout/fragment_encoding_config" />

                <TextView
                    android:id="@+id/tv_camera"
                    android:layout_width="220pt"
                    android:layout_height="48pt"
                    android:layout_marginTop="5pt"
                    android:background="@drawable/selector_r5_blue"
                    android:gravity="center"
                    android:text="Toggle camera config panel"
                    android:textColor="@color/textWhite"
                    android:textSize="@dimen/textSize14"
                    app:layout_constraintTop_toBottomOf="@+id/fragment_encoding_config" />

                <fragment
                    android:id="@+id/fragment_camera_config"
                    android:name="com.example.live.fragment.CameraConfigFragment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toBottomOf="@+id/tv_camera"
                    tools:layout="@layout/fragment_camera_config" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.core.widget.NestedScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48pt"
            android:layout_margin="10pt"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_copy_play_url"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/selector_r5_blue"
                android:gravity="center"
                android:text="PLAY URL"
                android:textColor="@color/textWhite"
                android:textSize="@dimen/textSize14" />

            <TextView
                android:id="@+id/tv_reauth_btn"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="5pt"
                android:layout_weight="1"
                android:background="@drawable/selector_r5_blue"
                android:gravity="center"
                android:text="Auth"
                android:textColor="@color/textWhite"
                android:textSize="@dimen/textSize14" />

            <TextView
                android:id="@+id/tv_qr_code"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:layout_marginStart="5pt"
                android:layout_weight="1"
                android:background="@drawable/selector_r5_blue"
                android:gravity="center"
                android:text="QR Code"
                android:textColor="@color/textWhite"
                android:textSize="@dimen/textSize14" />

            <TextView
                android:id="@+id/tv_launch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:layout_marginStart="5pt"
                android:layout_weight="1"
                android:background="@drawable/selector_r5_blue"
                android:gravity="center"
                android:text="LAUNCH"
                android:textColor="@color/textWhite"
                android:textSize="@dimen/textSize14" />

        </LinearLayout>

    </LinearLayout>

</layout>
