<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools" tools:ignore="NewApi">

    <!-- ====================== 相册基础样式 ====================== -->
    <style name="Album" />

    <!-- ====================== 按钮样式 ====================== -->
    <style name="Album.Button" parent="Widget.AppCompat.Button">
        <item name="android:theme">@style/Album.Theme.Button</item>
    </style>

    <!-- 按钮：包裹内容 -->
    <style name="Album.Button.WrapContent">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <!-- ====================== 复选框样式 ====================== -->
    <style name="Album.CheckBox" parent="Widget.AppCompat.CompoundButton.CheckBox" />

    <!-- 复选框：包裹内容 -->
    <style name="Album.CheckBox.WrapContent">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <!-- ====================== 对话框样式 ====================== -->
    <!-- 基础对话框：悬浮、半透明背景 -->
    <style name="Album.Dialog" parent="Theme.AppCompat.Light.Dialog">
        <item name="android:windowFrame">@null</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>

    <!-- 文件夹对话框：全屏、透明背景 -->
    <style name="Album.Dialog.Folder">
        <item name="android:windowBackground">@color/albumTransparent</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- ====================== 列表条目样式 ====================== -->
    <style name="Album.Item" />

    <!-- 卡片条目：带按压效果、圆角、阴影 -->
    <style name="Album.Item.Card">
        <item name="android:foreground">?selectableItemBackground</item>
        <item name="cardCornerRadius">@dimen/album_dp_2</item>
        <item name="cardElevation">@dimen/album_dp_2</item>
        <item name="cardPreventCornerOverlap">false</item>
    </style>

    <!-- 卡片条目：宽高充满 -->
    <style name="Album.Item.Card.MatchParent">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
    </style>

    <!-- ====================== 通用布局样式 ====================== -->
    <!-- 宽高充满父布局 -->
    <style name="Album.MatchParent">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
    </style>

    <!-- 底部栏：宽充满、固定高度 -->
    <style name="Album.MatchParent.SheetBottom">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/album_dp_45</item>
    </style>

    <!-- ====================== 进度条样式 ====================== -->
    <style name="Album.Progress" parent="Widget.AppCompat.ProgressBar" />

    <!-- 加载进度条：固定大小 -->
    <style name="Album.Progress.Loading">
        <item name="android:minWidth">@dimen/album_dp_40</item>
        <item name="android:maxWidth">@dimen/album_dp_40</item>
        <item name="android:minHeight">@dimen/album_dp_40</item>
        <item name="android:maxHeight">@dimen/album_dp_40</item>
        <item name="android:layout_width">@dimen/album_dp_40</item>
        <item name="android:layout_height">@dimen/album_dp_40</item>
    </style>

    <!-- ====================== 文字按钮 ====================== -->
    <style name="Album.TextButton" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog" />

    <!-- 文字按钮：包裹内容 -->
    <style name="Album.TextButton.WrapContent">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <!-- 底部文字按钮：居中、亮色、单行 -->
    <style name="Album.TextButton.WrapContent.SheetBottom">
        <item name="android:layout_gravity">center_vertical</item>
        <item name="android:ellipsize">end</item>
        <item name="android:maxLines">1</item>
        <item name="android:maxWidth">@dimen/album_dp_200</item>
        <item name="android:textColor">@color/albumFontLight</item>
    </style>

    <!-- ====================== 主题样式 ====================== -->
    <style name="Album.Theme" />

    <!-- Activity 基础主题：无标题栏、透明背景 -->
    <style name="Album.Theme.Activity" parent="@style/Theme.AppCompat.Light.DarkActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="android:windowBackground">@color/albumTransparent</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- 透明 Activity：无遮罩、无背景 -->
    <style name="Album.Theme.Activity.Transparent">
        <item name="android:windowFrame">@null</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <!-- 按钮主题 -->
    <style name="Album.Theme.Button" parent="@style/Theme.AppCompat.Light" />

    <style name="Album.Theme.Toolbar" />

    <!-- 深色 Toolbar 主题：白色文字 -->
    <style name="Album.Theme.Toolbar.Dark" parent="ThemeOverlay.AppCompat.Dark.ActionBar">
        <item name="actionMenuTextColor">@color/albumFontLight</item>
        <item name="textAllCaps">false</item>
    </style>

    <!-- 浅色 Toolbar 主题：黑色文字 -->
    <style name="Album.Theme.Toolbar.Light" parent="ThemeOverlay.AppCompat.Light">
        <item name="actionMenuTextColor">@color/albumFontDark</item>
        <item name="textAllCaps">false</item>
    </style>

    <!-- Toolbar 弹出菜单主题 -->
    <style name="Album.Theme.Toolbar.Popup" parent="ThemeOverlay.AppCompat.Light">
        <item name="actionMenuTextColor">@color/albumFontDark</item>
        <item name="textAllCaps">false</item>
    </style>

    <!-- ====================== Toolbar 样式 ====================== -->
    <style name="Album.Toolbar">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="popupTheme">@style/Album.Theme.Toolbar.Popup</item>
        <item name="elevation">@dimen/album_dp_0</item>
    </style>

    <!-- 深色 Toolbar -->
    <style name="Album.Toolbar.Dark" parent="Album.Toolbar">
        <item name="android:theme">@style/Album.Theme.Toolbar.Dark</item>
        <item name="titleTextColor">@color/albumFontLight</item>
        <item name="subtitleTextColor">@color/albumFontLight</item>
    </style>

    <!-- 浅色 Toolbar -->
    <style name="Album.Toolbar.Light" parent="Album.Toolbar">
        <item name="android:theme">@style/Album.Theme.Toolbar.Light</item>
        <item name="titleTextColor">@color/albumFontDark</item>
        <item name="subtitleTextColor">@color/albumFontDark</item>
    </style>

    <!-- ====================== 通用布局 ====================== -->
    <!-- 包裹内容 -->
    <style name="Album.WrapContent">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <!-- 可点击、带内边距的布局 -->
    <style name="Album.WrapContent.Transfer">
        <item name="android:clickable">true</item>
        <item name="android:padding">@dimen/album_dp_10</item>
    </style>

    <!-- 宽充满、高包裹 -->
    <style name="Album.WrapContent.WidthMatchParent">
        <item name="android:layout_width">match_parent</item>
    </style>

</resources>