<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center">

    <com.yanzhenjie.durban.widget.dialog.loading.LoadingView
        android:id="@+id/loading_view"
        android:layout_width="@dimen/gallery_dp_100"
        android:layout_height="@dimen/gallery_dp_100" />

    <TextView
        android:id="@+id/loading_tv_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:layout_marginStart="@dimen/gallery_dp_20"
        android:textColor="@color/galleryFontLight"
        android:textSize="@dimen/gallery_sp_16"
        tools:text="@string/durban_loading_message"
        tools:textColor="@android:color/black" />

</LinearLayout>