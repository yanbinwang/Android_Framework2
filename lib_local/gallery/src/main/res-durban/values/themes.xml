<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools" tools:ignore="NewApi">

    <!-- ====================== 裁剪基础样式 ====================== -->
    <style name="Durban" />

    <!-- ====================== 通用布局样式 ====================== -->
    <style name="Durban.WrapContent">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="Durban.WrapContent.ControllerButton">
        <item name="android:layout_gravity">center</item>
        <item name="android:scaleType">fitCenter</item>
    </style>

    <style name="Durban.WrapContent.WidthMatchParent">
        <item name="android:layout_width">match_parent</item>
    </style>

    <style name="Durban.WrapContent.WidthWeight">
        <item name="android:layout_width">@dimen/durban_dp_0</item>
        <item name="android:layout_weight">1</item>
    </style>

    <style name="Durban.WrapContent.WidthWeight.ControllerTitle">
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/galleryWhite</item>
    </style>

    <style name="Durban.MatchParent">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
    </style>

    <style name="Durban.MatchParent.ItemRoot">
        <item name="android:layout_height">@dimen/durban_dp_70</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="Durban.MatchParent.WidthWeight">
        <item name="android:layout_width">@dimen/durban_dp_0</item>
        <item name="android:layout_weight">1</item>
    </style>

    <style name="Durban.MatchParent.WidthWeight.ControllerItem">
        <item name="android:background">?selectableItemBackgroundBorderless</item>
        <item name="android:clickable">true</item>
    </style>

    <!-- ====================== Toolbar 样式 ====================== -->
    <style name="Durban.Toolbar">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <!-- 全透明 -->
        <item name="android:background">@android:color/transparent</item>
        <!-- 去掉阴影 -->
        <item name="android:elevation">@dimen/durban_dp_0</item>
        <!-- 去掉Toolbar左边默认的16dp留白 -->
        <item name="android:contentInsetStart">@dimen/durban_dp_0</item>
        <!-- 彻底隐藏标题 -->
        <item name="android:title">@null</item>
    </style>

</resources>