<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/galleryBackground">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        style="@style/Gallery.Toolbar"
        app:layout_constraintTop_toTopOf="parent"
        tools:background="@color/bgMain"
        tools:navigationIcon="@mipmap/gallery_ic_back">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:ellipsize="end"
            android:lines="1"
            android:textSize="@dimen/textSize18"
            android:textStyle="bold"
            tools:text="@string/gallery_album_title"
            tools:textColor="@color/galleryFontLight" />

    </androidx.appcompat.widget.Toolbar>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/layout_menu"
        android:layout_below="@+id/toolbar"
        android:overScrollMode="never"
        android:scrollbars="none" />

    <FrameLayout
        android:id="@+id/layout_menu"
        android:layout_width="match_parent"
        android:layout_height="34pt"
        android:layout_alignParentBottom="true"
        android:background="@color/albumMenuBackground">

        <LinearLayout
            android:id="@+id/layout_switch_dir"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="start"
            android:gravity="center"
            android:paddingHorizontal="10pt">

            <TextView
                android:id="@+id/tv_switch_dir"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:drawablePadding="2pt"
                android:gravity="center"
                android:textColor="@color/galleryFontLight"
                android:textSize="@dimen/textSize12"
                app:drawableEndCompat="@mipmap/album_abc_spinner" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_preview"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:gravity="center"
            android:paddingHorizontal="10pt">

            <TextView
                android:id="@+id/tv_preview"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:drawablePadding="2pt"
                android:gravity="center"
                android:textColor="@color/galleryFontLight"
                android:textSize="@dimen/textSize12"
                app:drawableStartCompat="@mipmap/album_ic_eye" />

        </LinearLayout>

    </FrameLayout>

    <LinearLayout
        android:id="@+id/layout_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/toolbar"
        android:background="@color/galleryBackground"
        android:gravity="center"
        android:visibility="visible"
        tools:visibility="gone">

        <com.example.gallery.widget.ColorProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="30pt"
            android:layout_height="30pt" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10pt"
            android:text="@string/album_loading"
            android:textColor="@color/galleryFontHint"
            android:textSize="@dimen/textSize14"
            android:textStyle="bold" />

    </LinearLayout>

</RelativeLayout>