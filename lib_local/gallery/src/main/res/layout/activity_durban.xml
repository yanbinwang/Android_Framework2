<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="MissingConstraints">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <FrameLayout
            android:id="@+id/fl_content"
            android:layout_width="match_parent"
            android:layout_height="0pt"
            android:background="@color/durban_CropBackground"
            app:layout_constraintBottom_toTopOf="@id/ll_controller"
            app:layout_constraintTop_toTopOf="parent">

            <com.yanzhenjie.durban.view.CropView
                android:id="@+id/crop_view"
                style="@style/durban_MatchParent"
                android:alpha="0" />

        </FrameLayout>

        <LinearLayout
            android:id="@+id/ll_controller"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/durban_ControllerBackground"
            android:orientation="vertical"
            android:paddingTop="10pt"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/fl_content">

            <LinearLayout
                android:id="@+id/ll_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tv_rotation_title"
                    android:layout_width="0pt"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/durban_controller_title_rotation"
                    android:textColor="@color/textWhite"
                    android:textSize="@dimen/textSize14" />

                <TextView
                    android:id="@+id/tv_scale_title"
                    android:layout_width="0pt"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/durban_controller_title_scale"
                    android:textColor="@color/textWhite"
                    android:textSize="@dimen/textSize14" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="70pt">

                <FrameLayout
                    android:id="@+id/fl_rotation_left"
                    android:layout_width="0pt"
                    android:layout_height="match_parent"
                    android:layout_weight="1">

                    <ImageView
                        android:layout_width="36pt"
                        android:layout_height="36pt"
                        android:layout_gravity="center"
                        android:src="@mipmap/durban_ic_rotation_90_left_white" />

                </FrameLayout>

                <FrameLayout
                    android:id="@+id/fl_rotation_right"
                    android:layout_width="0pt"
                    android:layout_height="match_parent"
                    android:layout_weight="1">

                    <ImageView
                        android:layout_width="36pt"
                        android:layout_height="36pt"
                        android:layout_gravity="center"
                        android:src="@mipmap/durban_ic_rotation_90_right_white" />

                </FrameLayout>

                <FrameLayout
                    android:id="@+id/fl_scale_big"
                    android:layout_width="0pt"
                    android:layout_height="match_parent"
                    android:layout_weight="1">

                    <ImageView
                        android:layout_width="36pt"
                        android:layout_height="36pt"
                        android:layout_gravity="center"
                        android:src="@mipmap/durban_ic_scale_out_white" />

                </FrameLayout>

                <FrameLayout
                    android:id="@+id/fl_scale_small"
                    android:layout_width="0pt"
                    android:layout_height="match_parent"
                    android:layout_weight="1">

                    <ImageView
                        android:layout_width="36pt"
                        android:layout_height="36pt"
                        android:layout_gravity="center"
                        android:src="@mipmap/durban_ic_scale_in_white" />

                </FrameLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>