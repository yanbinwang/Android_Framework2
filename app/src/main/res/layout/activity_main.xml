<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="adapter"
            type="com.example.mvvm.adapter.LanguageAdapter" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/fl_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bgToolbar">

            <com.example.common.widget.i18n.I18nTextView
                android:layout_width="match_parent"
                android:layout_height="44pt"
                android:gravity="center"
                android:text="@string/hint"
                android:textColor="@color/textPrimary"
                android:textSize="@dimen/textSize18"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/tv_mode_switcher"
                android:layout_width="37pt"
                android:layout_height="44pt"
                android:layout_gravity="end"
                android:paddingHorizontal="9pt"
                android:src="@mipmap/ic_mode_day" />

        </FrameLayout>

        <View style="@style/LineWidth" />

        <com.example.common.widget.i18n.I18nTextView
            android:layout_width="match_parent"
            android:layout_height="40pt"
            android:gravity="center_vertical"
            android:paddingHorizontal="20pt"
            android:text="@string/main_now_language"
            android:textColor="@color/textPrimary"
            android:textSize="@dimen/textSize14" />

        <TextView
            android:id="@+id/tv_language"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingHorizontal="20pt"
            android:textColor="@color/textSecondary"
            android:textSize="@dimen/textSize14"
            tools:text="English" />

        <View
            style="@style/LineWidth"
            android:layout_marginTop="20pt" />

        <com.example.common.widget.i18n.I18nTextView
            android:layout_width="match_parent"
            android:layout_height="40pt"
            android:gravity="center_vertical"
            android:paddingHorizontal="20pt"
            android:text="@string/main_now_header"
            android:textColor="@color/textPrimary"
            android:textSize="@dimen/textSize14" />

        <TextView
            android:id="@+id/tv_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingHorizontal="20pt"
            android:textColor="@color/textSecondary"
            android:textSize="@dimen/textSize14"
            tools:text="en_US" />

        <View
            style="@style/LineWidth"
            android:layout_marginTop="20pt" />

        <com.example.common.widget.xrecyclerview.XRecyclerView
            android:id="@+id/rec_list"
            quick_adapter="@{adapter}"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </LinearLayout>

</layout>
