<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        style="@style/Gallery.Toolbar"
        tools:background="@color/bgMain"
        tools:navigationIcon="@mipmap/gallery_ic_back">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:ellipsize="end"
            android:lines="1"
            android:textSize="@dimen/textSize18"
            android:textStyle="bold"
            tools:text="@string/gallery_durban_title"
            tools:textColor="@color/galleryFontLight" />

    </androidx.appcompat.widget.Toolbar>

    <FrameLayout
        android:id="@+id/content_frame"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/iv_controller_root"
        android:layout_below="@+id/toolbar"
        android:background="@color/durbanCropBackground">

        <com.example.gallery.feature.durban.widget.CropView
            android:id="@+id/crop_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0" />

    </FrameLayout>

    <LinearLayout
        android:id="@+id/iv_controller_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/durbanControllerBackground"
        android:orientation="vertical"
        android:paddingTop="5pt">

        <LinearLayout
            android:id="@+id/layout_controller_title_root"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tv_controller_title_rotation"
                android:layout_width="0pt"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/durban_controller_title_rotation"
                android:textColor="@color/galleryFontLight"
                android:textSize="@dimen/textSize12" />

            <TextView
                android:id="@+id/tv_controller_title_scale"
                android:layout_width="0pt"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/durban_controller_title_scale"
                android:textColor="@color/galleryFontLight"
                android:textSize="@dimen/textSize12" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50pt"
            android:gravity="center">

            <FrameLayout
                android:id="@+id/layout_controller_rotation_left"
                android:layout_width="0pt"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/iv_controller_rotation_left"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:scaleType="fitCenter"
                    android:src="@mipmap/durban_ic_rotation_90_left" />

            </FrameLayout>

            <FrameLayout
                android:id="@+id/layout_controller_rotation_right"
                android:layout_width="0pt"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/iv_controller_rotation_right"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:scaleType="fitCenter"
                    android:src="@mipmap/durban_ic_rotation_90_right" />

            </FrameLayout>

            <FrameLayout
                android:id="@+id/layout_controller_scale_big"
                android:layout_width="0pt"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/iv_controller_scale_big"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:scaleType="fitCenter"
                    android:src="@mipmap/durban_ic_scale_out" />

            </FrameLayout>

            <FrameLayout
                android:id="@+id/layout_controller_scale_small"
                android:layout_width="0pt"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="?selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/iv_controller_scale_small"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:scaleType="fitCenter"
                    android:src="@mipmap/durban_ic_scale_in" />

            </FrameLayout>

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
