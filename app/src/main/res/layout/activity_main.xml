<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="MissingConstraints">

    <data>

        <variable
            name="adapter"
            type="com.example.mvvm.adapter.DealAdapter" />

    </data>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/iv_home_bg"
            android:layout_width="match_parent"
            android:layout_height="163pt"
            android:scaleType="fitXY"
            android:src="@mipmap/bg_home" />

        <com.scwang.smart.refresh.layout.SmartRefreshLayout
            android:id="@+id/refresh"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:srlEnableLoadMore="false"
            app:srlEnableRefresh="true">

            <androidx.coordinatorlayout.widget.CoordinatorLayout
                android:id="@+id/cl_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <com.google.android.material.appbar.AppBarLayout
                    android:id="@+id/al_top"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:orientation="vertical"
                    app:elevation="0pt">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="44pt"
                        android:paddingHorizontal="10pt"
                        app:layout_scrollFlags="scroll">

                        <ImageView
                            android:id="@+id/iv_logo"
                            android:layout_width="149pt"
                            android:layout_height="20pt"
                            android:src="@mipmap/ic_logo"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/iv_customer"
                            android:layout_width="34pt"
                            android:layout_height="34pt"
                            android:padding="5pt"
                            android:src="@mipmap/ic_customer"
                            app:layout_constraintEnd_toStartOf="@id/iv_message"
                            app:layout_constraintTop_toTopOf="@id/iv_message" />

                        <ImageView
                            android:id="@+id/iv_message"
                            android:layout_width="34pt"
                            android:layout_height="34pt"
                            android:padding="5pt"
                            android:src="@mipmap/ic_message"
                            app:layout_constraintBottom_toBottomOf="@id/iv_logo"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/iv_logo" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:layout_scrollFlags="scroll">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <FrameLayout
                                android:id="@+id/fl_assets"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="80pt"
                                    android:gravity="center"
                                    android:text="顶部"
                                    android:textColor="@color/textPrimary"
                                    android:textSize="@dimen/textSize34" />

                            </FrameLayout>

                            <androidx.cardview.widget.CardView
                                android:layout_width="match_parent"
                                android:layout_height="108pt"
                                android:layout_marginHorizontal="15pt"
                                android:layout_marginTop="6pt"
                                app:cardBackgroundColor="@color/bgDefault"
                                app:cardCornerRadius="10pt"
                                app:cardElevation="0px">

                                <com.example.common.widget.advertising.Advertising
                                    android:id="@+id/vpBanner"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:nestedScrollingEnabled="false" />

                            </androidx.cardview.widget.CardView>

                        </LinearLayout>

                        <!-- 被折叠后顶部的白色背景 -->
                        <View
                            android:id="@+id/view_cover"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@color/bgWhite"
                            android:visibility="gone" />

                    </FrameLayout>

                    <!-- 不会被折叠的部分 -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cl_menu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:layout_scrollFlags="noScroll">

                        <ImageView
                            android:id="@+id/iv_menu"
                            android:layout_width="34pt"
                            android:layout_height="34pt"
                            android:layout_gravity="center"
                            android:layout_marginStart="10pt"
                            android:padding="5pt"
                            android:src="@mipmap/ic_menu"
                            app:layout_constraintStart_toStartOf="parent" />

                        <LinearLayout
                            android:id="@+id/ll_menu_btn"
                            android:layout_width="wrap_content"
                            android:layout_height="34pt"
                            android:layout_marginEnd="10pt"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:visibility="gone"
                            app:layout_constraintEnd_toEndOf="parent"
                            tools:visibility="visible">

                            <ImageView
                                android:layout_width="34pt"
                                android:layout_height="34pt"
                                android:padding="5pt"
                                android:src="@mipmap/ic_customer" />

                            <ImageView
                                android:layout_width="34pt"
                                android:layout_height="34pt"
                                android:padding="5pt"
                                android:src="@mipmap/ic_message" />

                            <ImageView
                                android:layout_width="34pt"
                                android:layout_height="34pt"
                                android:padding="5pt"
                                android:src="@mipmap/ic_search" />

                        </LinearLayout>

                        <!-- app:tabIndicator一定要再写一次 -->
                        <com.google.android.material.tabs.TabLayout
                            android:id="@+id/tb_menu"
                            android:layout_width="match_parent"
                            android:layout_height="44pt"
                            android:clipChildren="true"
                            android:clipToPadding="false"
                            android:paddingHorizontal="15pt"
                            android:theme="@style/TabLayoutStyle"
                            app:layout_constraintTop_toBottomOf="@+id/iv_menu"
                            app:tabIndicator="@drawable/layer_list_tab_line"
                            app:tabMode="scrollable" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </com.google.android.material.appbar.AppBarLayout>

                <FrameLayout
                    android:id="@+id/fl_list"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:layout_behavior="@string/appbar_scrolling_view_behavior">

                    <com.example.common.widget.xrecyclerview.XRecyclerView
                        android:id="@+id/rec_list"
                        quick_adapter="@{adapter}"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:empty="possess"
                        app:refresh="possess" />

                </FrameLayout>

            </androidx.coordinatorlayout.widget.CoordinatorLayout>

        </com.scwang.smart.refresh.layout.SmartRefreshLayout>

    </FrameLayout>

</layout>
