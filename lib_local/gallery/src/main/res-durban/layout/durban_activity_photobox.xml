<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Durban.MatchParent">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        style="@style/Gallery.Toolbar"
        tools:background="@color/galleryColorPrimary"
        tools:navigationIcon="@mipmap/gallery_ic_back">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:ellipsize="end"
            android:lines="1"
            android:textSize="@dimen/gallery_sp_18"
            android:textStyle="bold"
            tools:text="@string/gallery_durban_title"
            tools:textColor="@color/galleryFontLight" />

    </androidx.appcompat.widget.Toolbar>

    <FrameLayout
        android:id="@+id/content_frame"
        style="@style/Durban.MatchParent"
        android:layout_above="@id/iv_controller_root"
        android:layout_below="@id/toolbar"
        android:background="@color/durbanCropBackground">

        <com.yanzhenjie.durban.widget.CropView
            android:id="@+id/crop_view"
            style="@style/Durban.MatchParent"
            android:alpha="0" />

    </FrameLayout>

    <LinearLayout
        android:id="@+id/iv_controller_root"
        style="@style/Durban.WrapContent.WidthMatchParent"
        android:layout_alignParentBottom="true"
        android:background="@color/durbanControllerBackground"
        android:orientation="vertical"
        android:paddingTop="@dimen/gallery_dp_10">

        <LinearLayout
            android:id="@+id/layout_controller_title_root"
            style="@style/Durban.WrapContent.WidthMatchParent">

            <TextView
                android:id="@+id/tv_controller_title_rotation"
                style="@style/Durban.WrapContent.WidthWeight.ControllerTitle"
                android:text="@string/durban_controller_title_rotation" />

            <TextView
                android:id="@+id/tv_controller_title_scale"
                style="@style/Durban.WrapContent.WidthWeight.ControllerTitle"
                android:text="@string/durban_controller_title_scale" />

        </LinearLayout>

        <LinearLayout style="@style/Durban.MatchParent.ItemRoot">

            <FrameLayout
                android:id="@+id/layout_controller_rotation_left"
                style="@style/Durban.MatchParent.WidthWeight.ControllerItem">

                <ImageView
                    android:id="@+id/iv_controller_rotation_left"
                    style="@style/Durban.WrapContent.ControllerButton"
                    android:src="@mipmap/durban_ic_rotation_90_left" />

            </FrameLayout>

            <FrameLayout
                android:id="@+id/layout_controller_rotation_right"
                style="@style/Durban.MatchParent.WidthWeight.ControllerItem">

                <ImageView
                    android:id="@+id/iv_controller_rotation_right"
                    style="@style/Durban.WrapContent.ControllerButton"
                    android:src="@mipmap/durban_ic_rotation_90_right" />

            </FrameLayout>

            <FrameLayout
                android:id="@+id/layout_controller_scale_big"
                style="@style/Durban.MatchParent.WidthWeight.ControllerItem">

                <ImageView
                    android:id="@+id/iv_controller_scale_big"
                    style="@style/Durban.WrapContent.ControllerButton"
                    android:src="@mipmap/durban_ic_scale_out" />

            </FrameLayout>

            <FrameLayout
                android:id="@+id/layout_controller_scale_small"
                style="@style/Durban.MatchParent.WidthWeight.ControllerItem">

                <ImageView
                    android:id="@+id/iv_controller_scale_small"
                    style="@style/Durban.WrapContent.ControllerButton"
                    android:src="@mipmap/durban_ic_scale_in" />

            </FrameLayout>

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
